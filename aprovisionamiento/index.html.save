a\": -61.9, \"prev\": 274}, {\"Codigo\": \"BCEC350V08P\", \"descripcion\": \"BORNA HEMBRA CABLE 3,50 MM 8 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 468, \"alb\": 1, \"crec\": 0, \"tasa\": 0, \"prev\": 468}, {\"Codigo\": \"BCEC350V10P\", \"descripcion\": \"BORNA HEMBRA CABLE 3,50 MM 10 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 225, \"alb\": 1, \"crec\": -78.26, \"tasa\": -78.26, \"prev\": 49}, {\"Codigo\": \"BCEC381V02P\", \"descripcion\": \"BORNA HEMBRA CABLE 3,81 MM 2 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 900, \"alb\": 1, \"crec\": -85.92, \"tasa\": -85.92, \"prev\": 127}, {\"Codigo\": \"BCECH350R04P\", \"descripcion\": \"BORNA MACHO ACOD. PCB 3,50 MM 4 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 297, \"alb\": 1, \"crec\": -98.73, \"tasa\": -98.73, \"prev\": 4}, {\"Codigo\": \"BCECH350V05P\", \"descripcion\": \"BORNA MACHO RECTA PCB 3,50 MM 5 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 1800, \"alb\": 1, \"crec\": -4.76, \"tasa\": -4.76, \"prev\": 1714}, {\"Codigo\": \"BCECH381V06P\", \"descripcion\": \"BORNA MACHO RECTA PCB 3,81 MM 6 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 1800, \"alb\": 1, \"crec\": 700.0, \"tasa\": 30, \"prev\": 2340}, {\"Codigo\": \"BCEK508V02P\", \"descripcion\": \"BORNA PCB RECTA 5,08 MM 2 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 9, \"alb\": 1, \"crec\": -99.95, \"tasa\": -99.95, \"prev\": 0}, {\"Codigo\": \"BCEK508V03P\", \"descripcion\": \"BORNA PCB RECTA 5,08 MM 3 VIAS\", \"proveedor\": \"DINKLE INTERNA. (OPTIKLE) LTD.\", \"u2025\": 9, \"alb\": 1, \"crec\": -99.9, \"tasa\": -99.9, \"prev\": 0}], \"12\": []}";
  let datos = JSON.parse(datosJSON);
  let mesesActuales = [];
  let chart = null;

  function getMesesSeleccionados() {
    const select = document.getElementById('filtro-meses');
    const meses = Array.from(select.selectedOptions).map(o => o.value);
    return meses;
  }

  function actualizarSelectores() {
    mesesActuales = getMesesSeleccionados();

    const selectProveedor = document.getElementById('filtro-proveedor');
    const selectDesc = document.getElementById('filtro-desc');

    selectProveedor.innerHTML = '<option value="">-- Todos los proveedores --</option>';
    selectDesc.innerHTML = '<option value="">-- Todas las descripciones --</option>';

    if (mesesActuales.length === 0) {
      selectProveedor.disabled = true;
      selectDesc.disabled = true;
      document.getElementById('tabla').innerHTML = '<tr><td colspan="7" class="mensaje">Selecciona al menos un mes</td></tr>';
      document.getElementById('stats').innerHTML = '';
      actualizarGrafico([]);
      return;
    }

    selectProveedor.disabled = false;
    selectDesc.disabled = false;

    const proveedoresSet = new Set();
    const descripcionesSet = new Set();

    mesesActuales.forEach(mes => {
      const datosMes = datos[mes] || [];
      datosMes.forEach(item => {
        proveedoresSet.add(item.proveedor);
        descripcionesSet.add(item.descripcion);
      });
    });

    const proveedores = Array.from(proveedoresSet).sort();
    const descripciones = Array.from(descripcionesSet).sort();

    proveedores.forEach(prov => {
      const opt = document.createElement('option');
      opt.value = prov;
      opt.text = prov;
      selectProveedor.appendChild(opt);
    });

    descripciones.forEach(desc => {
      const opt = document.createElement('option');
      opt.value = desc;
      opt.text = desc.length > 60 ? desc.substring(0, 60) + '...' : desc;
      selectDesc.appendChild(opt);
    });

    mostrarDatos();
  }

  function mostrarDatos() {
    mesesActuales = getMesesSeleccionados();

    if (mesesActuales.length === 0) {
      document.getElementById('tabla').innerHTML = '<tr><td colspan="7" class="mensaje">Selecciona al menos un mes</td></tr>';
      document.getElementById('stats').innerHTML = '';
      actualizarGrafico([]);
      return;
    }

    const filtCodigo = document.getElementById('filtro-codigo').value.toLowerCase();
    const filtProveedor = document.getElementById('filtro-proveedor').value;
    const filtDesc = document.getElementById('filtro-desc').value;

    const datosAgrupados = {};

    mesesActuales.forEach(mes => {
      const datosMes = datos[mes] || [];
      datosMes.forEach(item => {
        const key = `${item.Codigo}|${item.descripcion}|${item.proveedor}`;

        if (!datosAgrupados[key]) {
          datosAgrupados[key] = {
            Codigo: item.Codigo,
            descripcion: item.descripcion,
            proveedor: item.proveedor,
            u2025: 0,
            alb: 0,
            crec: item.crec,
            tasa: item.tasa,
            prev: 0
          };
        }

        datosAgrupados[key].u2025 += item.u2025;
        datosAgrupados[key].alb += item.alb;
      });
    });

    Object.values(datosAgrupados).forEach(item => {
      item.prev = Math.round(item.u2025 * (1 + item.tasa/100));
    });

    let datosFiltrados = Object.values(datosAgrupados).filter(item => {
      const okCodigo = !filtCodigo || item.Codigo.toString().toLowerCase().includes(filtCodigo);
      const okProveedor = !filtProveedor || item.proveedor === filtProveedor;
      const okDesc = !filtDesc || item.descripcion === filtDesc;
      return okCodigo && okProveedor && okDesc;
    });

    datosFiltrados.sort((a, b) => b.prev - a.prev);

    const total2025 = datosFiltrados.reduce((sum, d) => sum + d.u2025, 0);
    const totalAlb = datosFiltrados.reduce((sum, d) => sum + d.alb, 0);
    const totalPrev = datosFiltrados.reduce((sum, d) => sum + d.prev, 0);
    const incremento = total2025 > 0 ? (((totalPrev - total2025) / total2025) * 100).toFixed(2) : 0;

    const mesesNombres = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
    const mesesTexto = mesesActuales.map(m => mesesNombres[m-1]).join(', ');

    document.getElementById('stats').innerHTML = 
      '<strong>Período:</strong> ' + mesesTexto + ' | ' +
      '<strong>' + datosFiltrados.length + '</strong> artículos | ' +
      '<strong>2025:</strong> ' + total2025.toLocaleString('es-ES') + ' | ' +
      '<strong>Albaranes:</strong> ' + totalAlb.toLocaleString('es-ES') + ' | ' +
      '<strong>Previsión 2026:</strong> ' + totalPrev.toLocaleString('es-ES') + ' | ' +
      '<strong>Incremento:</strong> +' + incremento + '%';

    const tbody = document.getElementById('tabla');
    if(datosFiltrados.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="mensaje">Sin resultados</td></tr>';
      actualizarGrafico([]);
      return;
    }

    tbody.innerHTML = datosFiltrados.map(d => `
      <tr>
        <td>${d.Codigo}</td>
        <td>${d.descripcion}</td>
        <td><span class="prov">${d.proveedor}</span></td>
        <td class="numero">${d.u2025.toLocaleString('es-ES')}</td>
        <td class="numero"><span class="albaranes">${d.alb}</span></td>
        <td class="numero">${d.crec.toFixed(2)}%</td>
        <td class="numero prevision">${d.prev.toLocaleString('es-ES')}</td>
      </tr>
    `).join('');

    actualizarGrafico(datosFiltrados);
  }

  function actualizarGrafico(datosFiltrados) {
    const ctx = document.getElementById('chart').getContext('2d');

    if(chart) chart.destroy();

    if (datosFiltrados.length === 0) {
      chart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: [],
          datasets: []
        }
      });
      return;
    }

    // Preparar etiquetas y datos para el gráfico
    const etiquetas = datosFiltrados.map(d => d.Codigo).slice(0, 15);
    const unidades2025 = datosFiltrados.map(d => d.u2025).slice(0, 15);
    const previsiones2026 = datosFiltrados.map(d => d.prev).slice(0, 15);

    chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: etiquetas,
        datasets: [
          {
            label: 'Unidades 2025',
            data: unidades2025,
            backgroundColor: 'rgba(102, 126, 234, 0.7)',
            borderColor: 'rgba(102, 126, 234, 1)',
            borderWidth: 1
          },
          {
            label: 'Previsión 2026',
            data: previsiones2026,
            backgroundColor: 'rgba(50, 205, 60, 0.7)',
            borderColor: 'rgba(50, 205, 60, 1)',
            borderWidth: 1
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: {
            labels: {
              color: '#e0e0e0',
              font: { size: 12 }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: '#444' },
            ticks: { color: '#a0a0b0' }
          },
          x: {
            grid: { color: '#444' },
            ticks: { color: '#a0a0b0' }
          }
        }
      }
    });
  }

  function limpiarFiltros() {
    document.getElementById('filtro-meses').selectedIndex = -1;
    document.getElementById('filtro-codigo').value = '';
    document.getElementById('filtro-proveedor').value = '';
    document.getElementById('filtro-proveedor').disabled = true;
    document.getElementById('filtro-desc').value = '';
    document.getElementById('filtro-desc').disabled = true;
    document.getElementById('tabla').innerHTML = '<tr><td colspan="7" class="mensaje">Selecciona al menos un mes</td></tr>';
    document.getElementById('stats').innerHTML = '';
    if(chart) chart.destroy();
  }

  function exportarCSV() {
    mesesActuales = getMesesSeleccionados();
    if(mesesActuales.length === 0) {
      alert('Selecciona al menos un mes primero');
      return;
    }

    const datosAgrupados = {};

    mesesActuales.forEach(mes => {
      const datosMes = datos[mes] || [];
      datosMes.forEach(item => {
        const key = `${item.Codigo}|${item.descripcion}|${item.proveedor}`;

        if (!datosAgrupados[key]) {
          datosAgrupados[key] = {
            Codigo: item.Codigo,
            descripcion: item.descripcion,
            proveedor: item.proveedor,
            u2025: 0,
            alb: 0,
            crec: item.crec,
            tasa: item.tasa,
            prev: 0
          };
        }

        datosAgrupados[key].u2025 += item.u2025;
        datosAgrupados[key].alb += item.alb;
      });
    });

    Object.values(datosAgrupados).forEach(item => {
      item.prev = Math.round(item.u2025 * (1 + item.tasa/100));
    });

    let csv = 'Código,Descripción,Proveedor,Unidades 2025,Albaranes,Crecimiento %,Tasa,Previsión 2026\n';

    Object.values(datosAgrupados).forEach(d => {
      csv += `"${d.Codigo}","${d.descripcion}","${d.proveedor}",${d.u2025},${d.alb},${d.crec},${d.tasa},${d.prev}\n`;
    });

    const blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    const mesesNombres = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
    const mesesTexto = mesesActuales.map(m => mesesNombres[m-1]).join('-');
    link.download = `prevision_${mesesTexto}_${new Date().toISOString().slice(0, 10)}.csv`;
    link.click();
  }
</script>
</body>
</html>
