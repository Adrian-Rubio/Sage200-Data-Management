<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Dashboard Previsión de Compras 2026</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body { 
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
    color: #e0e0e0;
    min-height: 100vh;
    padding: 20px;
  }

  .container { 
    max-width: 1400px; 
    margin: 0 auto; 
    background: #2a2a3e;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }

  .header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 30px;
    text-align: center;
    border-bottom: 2px solid #667eea;
  }

  .header h1 {
    font-size: 32px;
    margin-bottom: 8px;
    color: white;
    font-weight: 700;
  }

  .header p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 14px;
  }

  .contenido {
    padding: 30px;
  }

  .seccion {
    margin-bottom: 30px;
  }

  .seccion-titulo {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #667eea;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #444;
  }

  .filtros {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
    margin-bottom: 20px;
  }

  .filtro {
    display: flex;
    flex-direction: column;
  }

  .filtro label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    color: #667eea;
    margin-bottom: 6px;
    letter-spacing: 0.5px;
  }

  .filtro select,
  .filtro input[type="text"] {
    padding: 10px 12px;
    background: #1e1e2e;
    border: 1px solid #444;
    color: #e0e0e0;
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
  }

  .filtro select[multiple] {
    min-height: 120px;
  }

  .filtro select[multiple] option {
    padding: 8px 4px;
  }

  .filtro select[multiple] option:checked {
    background: #667eea;
    color: white;
  }

  .filtro select:focus,
  .filtro input[type="text"]:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .filtro select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .info-meses {
    font-size: 11px;
    color: #667eea;
    margin-top: 4px;
    font-style: italic;
  }

  .botones-accion {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .btn-limpiar {
    background: #667eea;
    color: white;
  }

  .btn-limpiar:hover {
    background: #764ba2;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  }

  .btn-exportar {
    background: #444;
    color: #e0e0e0;
  }

  .btn-exportar:hover {
    background: #555;
  }

  .stats {
    background: rgba(102, 126, 234, 0.1);
    border-left: 3px solid #667eea;
    padding: 12px;
    border-radius: 4px;
    font-size: 13px;
    margin-bottom: 20px;
    color: #b0b0c0;
  }

  .grafico-contenedor {
    background: #1e1e2e;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #444;
    margin-bottom: 30px;
  }

  .grafico-contenedor canvas {
    max-height: 400px;
  }

  .tabla-contenedor {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid #444;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: #1e1e2e;
  }

  th {
    background: #3a3a4e;
    color: #667eea;
    padding: 12px;
    text-align: left;
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid #444;
  }

  td {
    padding: 12px;
    border-bottom: 1px solid #333;
    font-size: 14px;
  }

  tr:hover {
    background: rgba(102, 126, 234, 0.05);
  }

  td:first-child {
    color: #667eea;
    font-weight: 600;
  }

  .numero {
    text-align: right;
    color: #a0a0b0;
  }

  .mensaje {
    text-align: center;
    padding: 50px 20px;
    color: #666;
    font-size: 14px;
  }

  .prov {
    background: rgba(102, 126, 234, 0.15);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
    color: #667eea;
    font-weight: 600;
  }

  .prevision {
    color: #76d776;
    font-weight: 700;
  }

  .albaranes {
    background: rgba(118, 215, 118, 0.15);
    padding: 4px 8px;
    border-radius: 4px;
    color: #76d776;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .header h1 { font-size: 24px; }
    .contenido { padding: 20px; }
    .filtros { grid-template-columns: 1fr; }
    .botones-accion { flex-direction: column; }
    .btn { width: 100%; }
    .filtro select[multiple] { min-height: 100px; }
  }
</style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📊 Previsión de Compras 2026</h1>
            <p>Basado en las ventas de 2024/2025</p>
        </div>

        <div class="contenido">
            <div class="seccion">
                <div class="seccion-titulo">🔍 Filtros</div>
                <div class="filtros">
                    <div class="filtro">
                        <label>🗓️ Meses (Ctrl+Click para seleccionar varios)</label>
                        <select id="filtro-meses" multiple onchange="actualizarSelectores()">
                            <option value="1">Enero</option>
                            <option value="2">Febrero</option>
                            <option value="3">Marzo</option>
                            <option value="4">Abril</option>
                            <option value="5">Mayo</option>
                            <option value="6">Junio</option>
                            <option value="7">Julio</option>
                            <option value="8">Agosto</option>
                            <option value="9">Septiembre</option>
                            <option value="10">Octubre</option>
                            <option value="11">Noviembre</option>
                            <option value="12">Diciembre</option>
                        </select>
                        <div class="info-meses">💡 Usa Ctrl (o Cmd en Mac) + Click para seleccionar múltiples</div>
                    </div>
                    <div class="filtro">
                        <label>Código</label>
                        <input type="text" id="filtro-codigo" placeholder="Buscar código..." oninput="mostrarDatos()" />
                    </div>
                    <div class="filtro">
                        <label>Proveedor</label>
                        <select id="filtro-proveedor" onchange="mostrarDatos()" disabled>
                            <option value="">-- Todos los proveedores --</option>
                        </select>
                    </div>
                    <div class="filtro">
                        <label>Descripción</label>
                        <select id="filtro-desc" onchange="mostrarDatos()" disabled>
                            <option value="">-- Todas las descripciones --</option>
                        </select>
                    </div>
                </div>

                <div class="botones-accion">
                    <button class="btn btn-limpiar" onclick="limpiarFiltros()">🔄 Limpiar</button>
                    <button class="btn btn-exportar" onclick="exportarCSV()">📥 Exportar CSV</button>
                </div>
            </div>

            <div class="stats" id="stats"></div>

            <div class="seccion">
                <div class="seccion-titulo">📈 Gráfico Comparativo 2025 vs Previsión 2026</div>
                <div class="grafico-contenedor">
                    <canvas id="chart"></canvas>
                </div>
            </div>

            <div class="tabla-contenedor">
                <table>
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Descripción</th>
                            <th>Proveedor</th>
                            <th class="numero">Unidades 2025</th>
                            <th class="numero">Albaranes</th>
                            <th class="numero">% Crecimiento</th>
                            <th class="numero">Previsión 2026</th>
                        </tr>
                    </thead>
                    <tbody id="tabla">
                        <tr><td colspan="7" class="mensaje">Selecciona al menos un mes para ver datos</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

<script>
